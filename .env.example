###########################
### LightRAG Server
###########################
# Bind to localhost for development. Use 0.0.0.0 only with LIGHTRAG_API_KEY or AUTH_ACCOUNTS.
HOST=127.0.0.1
PORT=9621
WORKSPACE=hongloumeng
WORKING_DIR=./data/rag_storage
INPUT_DIR=./data/inputs
PROMPT_DIR=./data/prompts
WEBUI_TITLE='红楼梦 LightRAG 关系图谱'
WEBUI_DESCRIPTION='面向高中语文整本书阅读的红楼梦知识图谱'

# Optional API key for server endpoints. Set before exposing beyond localhost.
# LIGHTRAG_API_KEY=replace-with-a-local-dev-api-key

########################################
### LLM configuration
########################################
# LightRAG supports openai, ollama, azure_openai, bedrock, gemini, lollms.
# For OpenAI-compatible providers, keep LLM_BINDING=openai and set the provider base URL.
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=replace-with-your-llm-api-key
LLM_MODEL=replace-with-your-chat-model
LLM_TIMEOUT=240
MAX_ASYNC_LLM=2

########################################
### Embedding configuration
########################################
# The embedding dimension must match the selected model exactly.
# If EMBEDDING_MODEL, EMBEDDING_DIM, EMBEDDING_ASYMMETRIC, or query/document prefixes change,
# clear data/rag_storage and rebuild the index.
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=replace-with-your-embedding-api-key
EMBEDDING_MODEL=replace-with-your-embedding-model
EMBEDDING_DIM=1024
EMBEDDING_FUNC_MAX_ASYNC=4
EMBEDDING_BATCH_NUM=8
# EMBEDDING_ASYMMETRIC=false
# EMBEDDING_QUERY_PREFIX=NO_PREFIX
# EMBEDDING_DOCUMENT_PREFIX=NO_PREFIX

########################################
### Optional role-specific LLMs
########################################
# Leave blank to inherit the base LLM. Fill these when you want cheaper extraction
# or stronger final answers. For cross-provider role overrides, set binding, host,
# model, and API key explicitly.
# EXTRACT_LLM_BINDING=openai
# EXTRACT_LLM_BINDING_HOST=https://api.openai.com/v1
# EXTRACT_LLM_BINDING_API_KEY=replace-with-your-extract-api-key
# EXTRACT_LLM_MODEL=replace-with-your-extract-model
# EXTRACT_MAX_ASYNC_LLM=2
# EXTRACT_LLM_TIMEOUT=240

# KEYWORD_LLM_BINDING=openai
# KEYWORD_LLM_BINDING_HOST=https://api.openai.com/v1
# KEYWORD_LLM_BINDING_API_KEY=replace-with-your-keyword-api-key
# KEYWORD_LLM_MODEL=replace-with-your-keyword-model
# KEYWORD_MAX_ASYNC_LLM=2
# KEYWORD_LLM_TIMEOUT=120

# QUERY_LLM_BINDING=openai
# QUERY_LLM_BINDING_HOST=https://api.openai.com/v1
# QUERY_LLM_BINDING_API_KEY=replace-with-your-query-api-key
# QUERY_LLM_MODEL=replace-with-your-query-model
# QUERY_MAX_ASYNC_LLM=2
# QUERY_LLM_TIMEOUT=240

########################################
### Ask open-question evidence pipeline
########################################
# Optional. Used by `make web` to understand open-ended Ask questions as a
# structured evidence contract. This model does not write factual answers; it only
# returns JSON fields such as question_focus, required_evidence, constraints,
# answer_shape, and subject_type_hint.
# Leave blank to inherit LLM_BINDING_HOST / LLM_BINDING_API_KEY / LLM_MODEL.
# HLM_ASK_PLANNER_BASE_URL=https://api.openai.com/v1
# HLM_ASK_PLANNER_API_KEY=replace-with-your-planner-api-key
# HLM_ASK_PLANNER_MODEL=replace-with-your-lightweight-chat-model
# HLM_ASK_PLANNER_TIMEOUT_SECONDS=20
# HLM_ASK_PLANNER_MAX_TOKENS=300
#
# Optional. Used by `make web` to judge whether each LightRAG/original-text
# candidate directly answers the user's question. It must only accept or reject
# evidence and extract supported spans; it must not invent facts outside the
# candidate text. If unset, it inherits the planner/general LLM settings.
# HLM_ASK_EVIDENCE_JUDGE_BASE_URL=https://api.openai.com/v1
# HLM_ASK_EVIDENCE_JUDGE_API_KEY=replace-with-your-judge-api-key
# HLM_ASK_EVIDENCE_JUDGE_MODEL=replace-with-your-lightweight-chat-model
# HLM_ASK_EVIDENCE_JUDGE_TIMEOUT_SECONDS=20
# HLM_ASK_EVIDENCE_JUDGE_MAX_TOKENS=500

########################################
### Local file storage defaults
########################################
KV_STORAGE=JsonKVStorage
VECTOR_STORAGE=NanoVectorDBStorage
GRAPH_STORAGE=NetworkXStorage
DOC_STATUS_STORAGE=JsonDocStatusStorage

########################################
### Hongloumeng document processing
########################################
SUMMARY_LANGUAGE=Chinese
ENTITY_EXTRACTION_USE_JSON=true
ENTITY_TYPE_PROMPT_FILE=hongloumeng_entity_type.yml

# Native text parser plus recursive chunking is a conservative default for long Chinese prose.
LIGHTRAG_PARSER=txt:native-teR;*:legacy-R
VLM_PROCESS_ENABLE=false

# Chinese novel chunking: prefer paragraph, line, and Chinese punctuation boundaries.
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=120
CHUNK_R_SIZE=1200
CHUNK_R_OVERLAP_SIZE=120
CHUNK_R_SEPARATORS=["\n\n","\n","。","！","？","；","，"," ",""]

# Keep graph provenance broad enough for chapter-level traceability.
MAX_SOURCE_IDS_PER_ENTITY=300
MAX_SOURCE_IDS_PER_RELATION=300
MAX_EXTRACT_INPUT_TOKENS=20480
MAX_EXTRACTION_RECORDS=120
MAX_EXTRACTION_ENTITIES=60
FORCE_LLM_SUMMARY_ON_MERGE=8
SUMMARY_MAX_TOKENS=1200
SUMMARY_LENGTH_RECOMMENDED=600
SUMMARY_CONTEXT_SIZE=12000

########################################
### Query defaults
########################################
ENABLE_LLM_CACHE=false
ENABLE_CONTENT_HEADINGS=true
TOP_K=40
CHUNK_TOP_K=20
KG_CHUNK_PICK_METHOD=VECTOR
RELATED_CHUNK_NUMBER=5
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000
RERANK_BINDING=null

########################################
### Pipeline controls
########################################
MAX_PARALLEL_INSERT=2
QUEUE_SIZE_PROCESS=4
QUEUE_SIZE_ANALYZE=20
QUEUE_SIZE_INSERT=4
